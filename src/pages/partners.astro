---
import { getSiteContent } from '../lib/data';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const { partnersContent } = getSiteContent();
---

<Layout title="Partners" description="Ontdek met welke partners Sebastiaan Peters samenwerkt voor professioneel schilderwerk in de regio Utrecht.">
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-[1400px] px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-4 reveal-left">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-1 mb-3">Samenwerkingen</p>
          <h1 class="text-4xl md:text-6xl font-bold tracking-tighter leading-[0.95]">Partners</h1>
        </div>
        <div class="lg:col-span-7 lg:col-start-6 reveal-right">
          <div class="text-base leading-relaxed text-neutral-600 space-y-5 [&>p]:text-base [&>p]:leading-relaxed" set:html={partnersContent} />
        </div>
      </div>
    </div>
  </section>
</Layout>
