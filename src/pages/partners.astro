---
import { getSiteContent } from '../lib/data';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const { partnersContent } = getSiteContent();
---

<Layout title="Partners" description="Ontdek met welke partners Sebastiaan Peters samenwerkt voor professioneel schilderwerk in de regio Utrecht.">
  <section class="py-20 md:py-32">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8 leading-[1.1]">Partners</h1>
        <div class="prose prose-lg max-w-none text-gray-600">
          <div class="space-y-6 [&>p]:text-xl [&>p]:leading-relaxed">
            <div set:html={partnersContent} />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
