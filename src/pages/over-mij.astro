---
import { getSiteContent } from '../lib/data';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const { aboutMe, businessInfo, profileImage } = getSiteContent();
---

<Layout title="Over mij" description="Lees meer over Sebastiaan Peters, professioneel binnen- en buitenschilder in de regio Utrecht." image={profileImage}>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Sebastiaan Peters",
      "description": "Professioneel binnen- en buitenschilder in de regio Utrecht",
      "image": "https://sebastiaanpeters.nl{profileImage}",
      "url": "https://sebastiaanpeters.nl/over-mij"
    }
  </script>

  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-[1400px] px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-5 reveal-left">
          <div class="lg:sticky lg:top-28">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-1 mb-3">Over mij</p>
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tighter leading-[0.95] mb-8">De man achter de kwast</h1>
            <div class="aspect-[3/4] overflow-hidden bg-neutral-100">
              <img src={profileImage} alt="Sebastiaan Peters" class="w-full h-full object-cover" loading="eager" />
            </div>
          </div>
        </div>
        <div class="lg:col-span-7 reveal-right">
          <div class="text-base leading-relaxed text-neutral-600 space-y-6 [&>p]:text-base [&>p]:leading-relaxed max-w-2xl" set:html={aboutMe} />
          <div class="mt-12 pt-12 border-t border-neutral-100">
            <div class="grid grid-cols-2 gap-8">
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-2">Telefoon</p>
                <p class="text-sm font-medium">{businessInfo.phone}</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-2">E-mail</p>
                <p class="text-sm font-medium">{businessInfo.email}</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-2">Locatie</p>
                <p class="text-sm font-medium">{businessInfo.location}</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-2">KvK</p>
                <p class="text-sm font-medium">{businessInfo.kvk}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
