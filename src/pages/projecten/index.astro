---
import { getAllProjects, DEFAULT_IMAGE } from '../../lib/data';
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const projecten = getAllProjects();
const firstProject = projecten[0];
const restProjects = projecten.slice(1);
---

<Layout title="Projecten" description="Overzicht van mijn recente schilderwerk.">
	<section class="py-24 md:py-32">
		<div class="mx-auto max-w-[1400px] px-6">
			<div class="max-w-xl reveal">
				<p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-1 mb-3">Portfolio</p>
				<h1 class="text-5xl md:text-7xl font-bold tracking-tighter leading-[0.9] mb-6">Projecten</h1>
				<p class="text-neutral-500 leading-relaxed">Een selectie van gerealiseerde projecten in de regio Utrecht.</p>
			</div>

			{firstProject && (
				<a
					href={`/projecten/${firstProject.slug}`}
					class="group block mt-16 reveal"
				>
					<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
						<div class="lg:col-span-7 overflow-hidden bg-neutral-100">
							<div class="aspect-[16/10]">
								<img
									src={firstProject.pictures[0] || DEFAULT_IMAGE}
									alt={firstProject.name}
									class="w-full h-full object-cover transition-transform duration-700 ease-spring group-hover:scale-105"
									loading="eager"
								/>
							</div>
						</div>
						<div class="lg:col-span-5">
							<p class="text-xs text-neutral-400 uppercase tracking-widest mb-3">Uitgelicht project</p>
							<h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4 group-hover:text-accent-1 transition-colors">{firstProject.name}</h2>
							<p class="text-sm text-neutral-500 leading-relaxed mb-6">{firstProject.paintType.join(', ')}</p>
							<span class="inline-flex items-center gap-2 text-sm font-medium text-accent-1">
								Bekijk project
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
							</span>
						</div>
					</div>
				</a>
			)}

			{restProjects.length > 0 && (
				<div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-20 mt-20 stagger-children">
					{restProjects.map((project) => (
						<a
							href={`/projecten/${project.slug}`}
							class="stagger-item group block"
						>
							<div class="overflow-hidden bg-neutral-100">
								<div class="aspect-[4/3]">
									<img
										src={project.pictures[0] || DEFAULT_IMAGE}
										alt={project.name}
										class="w-full h-full object-cover transition-transform duration-700 ease-spring group-hover:scale-105"
										loading="lazy"
									/>
								</div>
							</div>
							<div class="mt-5">
								<p class="text-xs text-neutral-400 uppercase tracking-widest mb-1.5">{project.paintType[0] || 'Schilderwerk'}</p>
								<h2 class="text-xl font-semibold tracking-tight group-hover:text-accent-1 transition-colors">{project.name}</h2>
							</div>
						</a>
					))}
				</div>
			)}

			{projecten.length === 0 && (
				<div class="mt-20 text-center py-20 border border-dashed border-neutral-200">
					<p class="text-neutral-400">Nog geen projecten toegevoegd.</p>
				</div>
			)}
		</div>
	</section>
</Layout>
