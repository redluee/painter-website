---
import { getAllProjects, DEFAULT_IMAGE } from '../../lib/data';
import Layout from '../../layouts/Layout.astro';
import StarRating from '../../components/StarRating.astro';

export const prerender = true;

const projecten = getAllProjects();
---

<Layout title="Projecten" description="Overzicht van mijn recente schilderwerk.">
  <section class="py-20">
    <div class="container mx-auto px-4">
      <h1 class="text-5xl font-bold mb-12 reveal">Projecten</h1>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {projecten.map((project, i) => (
          <a href={`/projecten/${project.slug}`} class:list={["group transition-all duration-300 hover:-translate-y-1", `reveal reveal-delay-${(i % 3) + 1}`]}>
            <div class="aspect-[4/5] bg-gray-100 mb-6 overflow-hidden transition-shadow duration-300">
              <img 
                src={project.pictures[0] || DEFAULT_IMAGE} 
                alt={project.name} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
            </div>
            <h2 class="text-xl font-bold mb-1 group-hover:text-accent-2 transition-colors">{project.name}</h2>
            <p class="text-sm text-gray-500 uppercase tracking-widest">{project.paintType.join(', ')}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
