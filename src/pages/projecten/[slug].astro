---
import { getProjectBySlugRuntime, DEFAULT_IMAGE } from '../../lib/data';
import Layout from '../../layouts/Layout.astro';
import ProjectGallery from '../../components/ProjectGallery.astro';
import StarRating from '../../components/StarRating.astro';

const { slug } = Astro.params;
const project = await getProjectBySlugRuntime(slug);

if (!project) {
  return Astro.redirect('/404', 302);
}
---

<Layout title={project.name} description={project.description} image={project.pictures[0] || undefined}>
  <article class="container mx-auto px-4 py-20">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sebastiaanpeters.nl/" },
          { "@type": "ListItem", "position": 2, "name": "Projecten", "item": "https://sebastiaanpeters.nl/projecten" },
          { "@type": "ListItem", "position": 3, "name": "{project.name}", "item": "https://sebastiaanpeters.nl/projecten/{project.slug}" }
        ]
      }
    </script>
    <div class="max-w-4xl mx-auto">
      <header class="mb-12 reveal">
        <div class="flex items-center gap-4 text-sm text-gray-500 uppercase tracking-widest mb-4">
          <span>{project.paintType.join(' • ')}</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-bold mb-8 text-balance">{project.name}</h1>
      </header>

      <div class="reveal reveal-delay-1">
        <ProjectGallery pictures={project.pictures} projectName={project.name} />
      </div>

      <div class="prose prose-lg max-w-none reveal reveal-delay-2">
        <div set:html={project.description} class="text-xl leading-relaxed text-gray-600 space-y-4 [&>p]:text-xl [&>p]:leading-relaxed" />
      </div>

      <footer class="mt-20 pt-12 border-t border-gray-100 reveal reveal-delay-3">
        <div class="bg-gray-50 p-8 md:p-12 text-center">
          <h2 class="text-2xl font-bold mb-6">Interesse in een soortgelijk project?</h2>
          <p class="text-gray-600 mb-8 max-w-xl mx-auto">
            Ik denk graag met u mee over de mogelijkheden voor uw woning of bedrijfspand.
          </p>
          <a href="/contact" class="inline-block px-10 py-4 bg-accent-1 text-white font-medium rounded-full hover:bg-accent-2 active:scale-[0.97] transition-all duration-200">
            Vraag een vrijblijvende offerte aan
          </a>
        </div>
      </footer>
    </div>
  </article>
</Layout>
