---
import { getAllProjects, getSiteContent, DEFAULT_IMAGE } from '../lib/data';
import Layout from '../layouts/Layout.astro';
import StarRating from '../components/StarRating.astro';

export const prerender = true;

const { businessInfo } = getSiteContent();
const recentProjects = getAllProjects().slice(0, 3);
---

<Layout title="Home">
	<section class="py-20 md:py-32">
		<div class="container mx-auto px-4">
			<div class="max-w-3xl">
				<h1 class="text-4xl md:text-7xl font-bold tracking-tight mb-8 leading-[1.1] select-none">
					<span class="flex items-start">
						<span class="text-[2.6em] leading-[0.8] shrink-0 select-none">B</span>
						<span>innen- &<br />uitenschilderwerk</span>
					</span>
					<span class="relative inline-block mt-4">
						<img src="/brushstroke.svg" alt="" class="absolute pointer-events-none select-none brushstroke-reveal pl-2" style="left:50%;top:50%;transform:scale(1.5) translate(-38%,-26%);filter:drop-shadow(-5px 0px 5px rgba(0,0,0,.35))" aria-hidden="true" />
						<span class="relative font-['Permanent_Marker'] select-none" style="color:rgba(255, 255, 255, 0.88);font-weight:400">met oog voor detail.</span>
					</span>
				</h1>
				<p class="text-xl text-gray-600 mb-12 leading-relaxed pt-3">
					{businessInfo.intro}
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a href="/projecten" class="px-8 py-4 bg-accent-1 text-white font-medium rounded-full text-center hover:bg-accent-2 transition-colors">
						Bekijk mijn werk
					</a>
					<a href="/contact" class="px-8 py-4 bg-white border border-accent-1 text-accent-1 font-medium rounded-full text-center hover:bg-accent-1 hover:text-white transition-colors">
						Neem contact op
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="py-20 bg-section-bg">
		<div class="container mx-auto px-4">
			<div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
				<div>
					<h2 class="text-3xl font-bold mb-4">Recente Projecten</h2>
					<p class="text-gray-500">Ontdek mijn laatste realisaties in de regio.</p>
				</div>
				<a href="/projecten" class="group relative inline-block text-sm font-bold uppercase tracking-widest text-accent-1 pb-1 overflow-hidden">
						Alle projecten
						<span class="absolute bottom-0 right-0 h-0.5 bg-accent-1 transition-all duration-300 w-8 group-hover:w-full"></span>
					</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{recentProjects.map(project => (
					<a href={`/projecten/${project.slug}`} class="group cursor-pointer">
						<div class="aspect-4/5 bg-gray-200 mb-6 overflow-hidden">
							<div
								class="w-full h-full group-hover:scale-105 transition-transform duration-700 bg-cover bg-center"
								style={`background-image: url('${project.pictures[0] || DEFAULT_IMAGE}')`}
							></div>
						</div>
						{project.review && <div class="mb-2"><StarRating stars={project.review.stars} size={16} /></div>}
						<h3 class="text-xl font-bold mb-1">{project.name}</h3>
						<p class="text-sm text-gray-500">{project.paintType.join(', ')}</p>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>

<style>
	@keyframes reveal-left-to-right {
		from { clip-path: inset(0 100% 0 0); }
		to { clip-path: inset(0 0 0 0); }
	}
	.brushstroke-reveal {
		animation: reveal-left-to-right 1s ease-out forwards;
	}
</style>
