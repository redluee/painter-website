---
import { getAllProjects, getSiteContent, DEFAULT_IMAGE } from '../lib/data';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const { businessInfo } = getSiteContent();
const recentProjects = getAllProjects().slice(0, 3);
---

<Layout title="Home">
	<section class="py-20 md:py-32">
		<div class="container mx-auto px-4">
			<div class="max-w-3xl">
				<h1 class="text-4xl md:text-7xl font-bold tracking-tight mb-8 leading-[1.1]">
					Binnen- & buitenschilderwerk <br />
					<span class="text-gray-400">met oog voor detail.</span>
				</h1>
				<p class="text-xl text-gray-600 mb-12 leading-relaxed">
					{businessInfo.intro}
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a href="/projecten" class="px-8 py-4 bg-black text-white font-medium rounded-full text-center hover:bg-gray-800 transition-colors">
						Bekijk mijn werk
					</a>
					<a href="/contact" class="px-8 py-4 bg-white border border-gray-200 text-black font-medium rounded-full text-center hover:bg-gray-50 transition-colors">
						Neem contact op
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="py-20 bg-gray-50">
		<div class="container mx-auto px-4">
			<div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
				<div>
					<h2 class="text-3xl font-bold mb-4">Recente Projecten</h2>
					<p class="text-gray-500">Ontdek mijn laatste realisaties in de regio.</p>
				</div>
				<a href="/projecten" class="text-sm font-bold uppercase tracking-widest border-b-2 border-black pb-1">Alle projecten</a>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{recentProjects.map(project => (
					<a href={`/projecten/${project.slug}`} class="group cursor-pointer">
						<div class="aspect-[4/5] bg-gray-200 mb-6 overflow-hidden">
							<div
								class="w-full h-full group-hover:scale-105 transition-transform duration-700 bg-cover bg-center"
								style={`background-image: url('${project.pictures[0] || DEFAULT_IMAGE}')`}
							></div>
						</div>
						<h3 class="text-xl font-bold mb-1">{project.name}</h3>
						<p class="text-sm text-gray-500">{project.paintType.join(', ')}</p>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>
