---
import { getSiteContent } from '../lib/data';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const { businessInfo } = getSiteContent();
---

<Layout title="Contact" description="Neem contact op voor een vrijblijvende offerte.">
  <section class="py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-20">
        <div class="reveal">
          <h1 class="text-5xl font-bold mb-8 text-balance">Laten we praten over uw project.</h1>
          <p class="text-xl text-gray-600 mb-12 leading-relaxed">
            Heeft u een vraag over mijn schilderwerk of wilt u direct een offerte aanvragen?
            Vul het formulier in of neem direct contact op via onderstaande gegevens.
          </p>

          <div class="space-y-8">
            <div>
				<h2 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">Bel mij</h2>
              <p class="text-xl">{businessInfo.phone}</p>
            </div>
            <div>
				<h2 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">E-mail mij</h2>
              <p class="text-xl">{businessInfo.email}</p>
            </div>
            <div>
				<h2 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">Locatie</h2>
              <p class="text-xl">{businessInfo.location}</p>
            </div>
          </div>
        </div>

        <div class="bg-gray-50 p-8 md:p-12 reveal reveal-delay-1">
          <form id="contact-form" class="space-y-6" novalidate>
            <div>
              <label for="name" class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Volledige Naam</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-white border border-gray-200 focus:outline-none focus:border-accent-1 transition-colors"
              />
              <p id="name-error" class="text-sm text-red-600 hidden mt-1" role="alert"></p>
            </div>
            <div>
              <label for="email" class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">E-mailadres</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-white border border-gray-200 focus:outline-none focus:border-accent-1 transition-colors"
              />
              <p id="email-error" class="text-sm text-red-600 hidden mt-1" role="alert"></p>
            </div>
            <div>
              <label for="subject" class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Onderwerp</label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 bg-white border border-gray-200 focus:outline-none focus:border-accent-1 transition-colors"
              >
                <option value="offerte">Offerte aanvraag</option>
                <option value="vraag">Algemene vraag</option>
                <option value="anders">Anders</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-2">Uw bericht</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 bg-white border border-gray-200 focus:outline-none focus:border-accent-1 transition-colors"
              ></textarea>
              <p id="message-error" class="text-sm text-red-600 hidden mt-1" role="alert"></p>
            </div>

            <p id="contact-error" class="text-sm text-red-600 hidden" role="alert"></p>
            <p id="contact-success" class="text-sm text-green-600 hidden" role="status"></p>

            <button type="submit" id="contact-submit" class="w-full py-4 bg-accent-1 text-white font-medium hover:bg-accent-2 active:scale-[0.97] transition-all duration-200">
              Verstuur Bericht
            </button>
          </form>
        </div>

        <script>
          const form = document.getElementById('contact-form');
          const errorEl = document.getElementById('contact-error');
          const successEl = document.getElementById('contact-success');
          const submitBtn = document.getElementById('contact-submit');

          function validateField(id, getError) {
            const el = document.getElementById(id);
            const errorEl = document.getElementById(id + '-error');
            const value = el.value.trim();
            const error = getError(value);
            if (error) {
              el.classList.add('border-red-500', 'focus:border-red-500');
              el.classList.remove('focus:border-accent-1');
              errorEl.textContent = error;
              errorEl.classList.remove('hidden');
              return false;
            } else {
              el.classList.remove('border-red-500', 'focus:border-red-500');
              el.classList.add('focus:border-accent-1');
              errorEl.classList.add('hidden');
              return true;
            }
          }

          const validators = {
            name: (v) => !v ? 'Naam is verplicht.' : null,
            email: (v) => !v ? 'E-mailadres is verplicht.' : (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? 'Voer een geldig e-mailadres in.' : null),
            message: (v) => !v ? 'Bericht is verplicht.' : null,
          };

          ['name', 'email', 'message'].forEach(function (id) {
            const el = document.getElementById(id);
            el.addEventListener('blur', function () {
              validateField(id, validators[id]);
            });
            el.addEventListener('input', function () {
              if (el.classList.contains('border-red-500')) {
                validateField(id, validators[id]);
              }
            });
          });

          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorEl.classList.add('hidden');
            successEl.classList.add('hidden');

            let valid = true;
            Object.keys(validators).forEach(function (id) {
              if (!validateField(id, validators[id])) valid = false;
            });
            if (!valid) return;

            submitBtn.disabled = true;
            submitBtn.textContent = 'Verzenden...';

            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  name: document.getElementById('name').value,
                  email: document.getElementById('email').value,
                  subject: document.getElementById('subject').value,
                  message: document.getElementById('message').value,
                }),
              });

              const data = await res.json();

              if (res.ok) {
                successEl.textContent = data.message || 'Bedankt! Uw bericht is verzonden.';
                successEl.classList.remove('hidden');
                form.reset();
                ['name', 'email', 'message'].forEach(function (id) {
                  document.getElementById(id + '-error').classList.add('hidden');
                  document.getElementById(id).classList.remove('border-red-500', 'focus:border-red-500');
                });
              } else {
                errorEl.textContent = data.error || 'Verzenden mislukt.';
                errorEl.classList.remove('hidden');
              }
            } catch {
              errorEl.textContent = 'Er is iets misgegaan. Probeer het opnieuw.';
              errorEl.classList.remove('hidden');
            } finally {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Verstuur Bericht';
            }
          });
        </script>
      </div>
    </div>
  </section>
</Layout>
