---
import { getSiteContent } from '../lib/data';
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const { businessInfo } = getSiteContent();
---

<Layout title="Contact" description="Neem contact op voor een vrijblijvende offerte.">
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-[1400px] px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
        <div class="lg:col-span-5 reveal-left">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-1 mb-3">Contact</p>
          <h1 class="text-4xl md:text-6xl font-bold tracking-tighter leading-[0.95] mb-6">Laten we praten over uw project</h1>
          <p class="text-neutral-500 leading-relaxed mb-12 max-w-sm">
            Heeft u een vraag of wilt u direct een offerte aanvragen? Ik reageer binnen 24 uur.
          </p>

          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-section-bg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent-1"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Bel mij</p>
                <p class="font-medium text-sm">{businessInfo.phone}</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-section-bg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent-1"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">E-mail mij</p>
                <p class="font-medium text-sm">{businessInfo.email}</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-section-bg flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent-1"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">Locatie</p>
                <p class="font-medium text-sm">{businessInfo.location}</p>
              </div>
            </div>
          </div>

          <div class="mt-10 pt-10 border-t border-neutral-100">
            <a href="https://wa.me/{businessInfo.phone.replace(/[^\d]/g, '')}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-accent-1 hover:text-accent-2 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Stuur een WhatsApp-bericht
            </a>
          </div>
        </div>

        <div class="lg:col-span-7 reveal-right">
          <form id="contact-form" class="space-y-6" novalidate>
            <div class="space-y-2">
              <label for="name" class="block text-xs font-semibold uppercase tracking-widest text-neutral-500">Volledige naam</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 focus:outline-none focus:border-accent-1 focus:bg-white transition-all duration-300 ease-spring text-sm"
              />
              <p id="name-error" class="text-xs text-red-500 hidden mt-1" role="alert"></p>
            </div>
            <div class="space-y-2">
              <label for="email" class="block text-xs font-semibold uppercase tracking-widest text-neutral-500">E-mailadres</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 focus:outline-none focus:border-accent-1 focus:bg-white transition-all duration-300 ease-spring text-sm"
              />
              <p id="email-error" class="text-xs text-red-500 hidden mt-1" role="alert"></p>
            </div>
            <div class="space-y-2">
              <label for="subject" class="block text-xs font-semibold uppercase tracking-widest text-neutral-500">Onderwerp</label>
              <select
                id="subject"
                name="subject"
                class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 focus:outline-none focus:border-accent-1 focus:bg-white transition-all duration-300 ease-spring text-sm"
              >
                <option value="offerte">Offerte aanvraag</option>
                <option value="vraag">Algemene vraag</option>
                <option value="anders">Anders</option>
              </select>
            </div>
            <div class="space-y-2">
              <label for="message" class="block text-xs font-semibold uppercase tracking-widest text-neutral-500">Uw bericht</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 bg-neutral-50 border border-neutral-200 focus:outline-none focus:border-accent-1 focus:bg-white transition-all duration-300 ease-spring text-sm resize-none"
              ></textarea>
              <p id="message-error" class="text-xs text-red-500 hidden mt-1" role="alert"></p>
            </div>

            <p id="contact-error" class="text-sm text-red-500 hidden" role="alert"></p>
            <p id="contact-success" class="text-sm text-accent-1 hidden" role="status"></p>

            <button type="submit" id="contact-submit" class="w-full py-3.5 bg-accent-1 text-white text-sm font-medium rounded-full hover:bg-accent-2 active:scale-[0.97] transition-all duration-300 ease-spring flex items-center justify-center gap-2">
              <span id="submit-text">Verstuur bericht</span>
              <svg id="submit-spinner" class="hidden animate-spin w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>

    <script>
      const form = document.getElementById('contact-form');
      const errorEl = document.getElementById('contact-error');
      const successEl = document.getElementById('contact-success');
      const submitBtn = document.getElementById('contact-submit');

      function validateField(id, getError) {
        const el = document.getElementById(id);
        const errorEl = document.getElementById(id + '-error');
        const value = el.value.trim();
        const error = getError(value);
        if (error) {
          el.classList.add('border-red-400');
          el.classList.remove('focus:border-accent-1', 'border-neutral-200');
          errorEl.textContent = error;
          errorEl.classList.remove('hidden');
          return false;
        } else {
          el.classList.remove('border-red-400');
          el.classList.add('border-neutral-200', 'focus:border-accent-1');
          errorEl.classList.add('hidden');
          return true;
        }
      }

      const validators = {
        name: (v) => !v ? 'Naam is verplicht.' : null,
        email: (v) => !v ? 'E-mailadres is verplicht.' : (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) ? 'Voer een geldig e-mailadres in.' : null),
        message: (v) => !v ? 'Bericht is verplicht.' : null,
      };

      ['name', 'email', 'message'].forEach(function (id) {
        const el = document.getElementById(id);
        el.addEventListener('blur', function () {
          validateField(id, validators[id]);
        });
        el.addEventListener('input', function () {
          if (el.classList.contains('border-red-400')) {
            validateField(id, validators[id]);
          }
        });
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.classList.add('hidden');
        successEl.classList.add('hidden');

        let valid = true;
        Object.keys(validators).forEach(function (id) {
          if (!validateField(id, validators[id])) valid = false;
        });
        if (!valid) return;

        submitBtn.disabled = true;
        document.getElementById('submit-text').textContent = 'Verzenden...';
        document.getElementById('submit-spinner').classList.remove('hidden');

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: document.getElementById('name').value,
              email: document.getElementById('email').value,
              subject: document.getElementById('subject').value,
              message: document.getElementById('message').value,
            }),
          });

          const data = await res.json();

          if (res.ok) {
            successEl.textContent = data.message || 'Bedankt! Uw bericht is verzonden.';
            successEl.classList.remove('hidden');
            form.reset();
            ['name', 'email', 'message'].forEach(function (id) {
              document.getElementById(id + '-error').classList.add('hidden');
              document.getElementById(id).classList.remove('border-red-400', 'focus:border-red-400');
              document.getElementById(id).classList.add('border-neutral-200', 'focus:border-accent-1');
            });
          } else {
            errorEl.textContent = data.error || 'Verzenden mislukt. Probeer het opnieuw.';
            errorEl.classList.remove('hidden');
          }
        } catch {
          errorEl.textContent = 'Er is iets misgegaan. Probeer het opnieuw.';
          errorEl.classList.remove('hidden');
        } finally {
          submitBtn.disabled = false;
          document.getElementById('submit-text').textContent = 'Verstuur bericht';
          document.getElementById('submit-spinner').classList.add('hidden');
        }
      });
    </script>
  </section>
</Layout>
