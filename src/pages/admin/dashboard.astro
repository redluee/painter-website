---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <a href="/admin/content" class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow group">
      <h3 class="text-lg font-bold text-gray-900 group-hover:text-accent-2 transition-colors mb-2">Inhoud</h3>
      <p class="text-sm text-gray-500">Bewerk de website-teksten: bedrijfsgegevens en over mij.</p>
    </a>

    <a href="/admin/projects" class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow group">
      <h3 class="text-lg font-bold text-gray-900 group-hover:text-accent-2 transition-colors mb-2">Projecten</h3>
      <p class="text-sm text-gray-500">Beheer projecten: voeg toe, bewerk of verwijder projecten en afbeeldingen.</p>
    </a>

    <a href="/admin/instellingen" class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow group">
      <h3 class="text-lg font-bold text-gray-900 group-hover:text-accent-2 transition-colors mb-2">Kleur instellingen</h3>
      <p class="text-sm text-gray-500">Pas de website-kleuren aan: accenten en achtergronden.</p>
    </a>
  </div>
</AdminLayout>
