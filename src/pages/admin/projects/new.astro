---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Nieuw project">
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 md:p-8">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Nieuw project</h2>

    <form id="project-form" class="space-y-6">
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Projectnaam</label>
        <input type="text" id="name" required
          class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent-1 focus:border-transparent"
          placeholder="Bijv. Historisch Grachtenpand" />
      </div>

      <div>
        <label for="paintType" class="block text-sm font-medium text-gray-700 mb-1">Type verfwerk (komma-gescheiden)</label>
        <input type="text" id="paintType"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent-1 focus:border-transparent"
          placeholder="Bijv. buiten, historisch" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Beschrijving</label>
        <p class="text-xs text-gray-400 mb-2">Gebruik <strong>Ctrl+B</strong> voor vet, <strong>Ctrl+I</strong> voor cursief.</p>
        <div id="description-editor" class="bg-white border border-gray-300 rounded-xl overflow-hidden quill-custom"></div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Review (optioneel)</label>
        <p class="text-xs text-gray-400 mb-2">Beoordeling van de klant.</p>
        <div class="flex gap-1 mb-3 select-none" id="review-stars">
          {[1, 2, 3, 4, 5].map(i => (
            <div class="star-unit relative w-8 h-8 cursor-pointer" data-star={i} aria-label={`${i} ster`}>
              <svg class="star-empty absolute inset-0 w-full h-full text-gray-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
              <svg class="star-fill absolute inset-0 w-full h-full text-amber-400" fill="currentColor" stroke="none" viewBox="0 0 24 24" style="clip-path:inset(0 100% 0 0)">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
            </div>
          ))}
        </div>
        <input type="hidden" id="review-stars-value" value="0" />
        <textarea id="review-description" rows="3"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-accent-1 focus:border-transparent"
          placeholder="Wat vond de klant van het werk?"></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Afbeeldingen</label>
        <div
          id="dropzone"
          class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center cursor-pointer hover:border-gray-400 transition-colors"
        >
          <p class="text-sm text-gray-500 mb-1">Sleep afbeeldingen hierheen of klik om te uploaden</p>
          <p class="text-xs text-gray-400">JPG, PNG, WebP of AVIF (max 10 MB per stuk)</p>
        </div>
        <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/avif" multiple class="hidden" />
        <div id="image-previews" class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4"></div>
      </div>

      <p id="error-message" class="text-sm text-red-600 hidden" role="alert"></p>

      <div class="flex gap-3">
        <button type="submit"
          class="px-8 py-3 bg-accent-1 text-white text-sm font-medium rounded-xl hover:bg-accent-2 transition-colors">
          Project aanmaken
        </button>
        <a href="/admin/projects"
          class="px-8 py-3 border border-gray-300 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-50 transition-colors">
          Annuleren
        </a>
      </div>
    </form>
  </div>

  <style>
    .quill-custom .ql-editor {
      font-family: inherit;
      font-size: 0.875rem;
      line-height: 1.625;
      min-height: 150px;
    }
    .quill-custom .ql-toolbar {
      border-top-left-radius: 0.75rem;
      border-top-right-radius: 0.75rem;
      border-bottom: 1px solid #e5e7eb;
    }
    .quill-custom .ql-container {
      border: none;
      font-family: inherit;
    }
  </style>

  <script>
    import Quill from 'quill';
    import 'quill/dist/quill.snow.css';

    const form = document.getElementById('project-form');
    const errorEl = document.getElementById('error-message');
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('file-input');
    const imagePreviews = document.getElementById('image-previews');
    const reviewStarsInput = document.getElementById('review-stars-value');
    let uploadedUrls = [];
    let draggedUrl = null;
    let selectedStars = 0;

    function updateStars(value) {
      document.querySelectorAll('#review-stars .star-unit').forEach((el, i) => {
        const pct = Math.min(1, Math.max(0, value - i)) * 100;
        el.querySelector('.star-fill').style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
      });
    }

    const starsContainer = document.getElementById('review-stars');

    starsContainer.addEventListener('mousemove', (e) => {
      const unit = e.target.closest('.star-unit');
      if (!unit) return;
      const pos = parseInt(unit.dataset.star);
      const rect = unit.getBoundingClientRect();
      const isLeft = (e.clientX - rect.left) < rect.width / 2;
      updateStars(isLeft ? pos - 0.5 : pos);
    });

    starsContainer.addEventListener('mouseleave', () => {
      updateStars(selectedStars);
    });

    starsContainer.addEventListener('click', (e) => {
      const unit = e.target.closest('.star-unit');
      if (!unit) return;
      const pos = parseInt(unit.dataset.star);
      const rect = unit.getBoundingClientRect();
      const isLeft = (e.clientX - rect.left) < rect.width / 2;
      selectedStars = isLeft ? pos - 0.5 : pos;
      reviewStarsInput.value = selectedStars;
      updateStars(selectedStars);
    });

    const descriptionEditor = new Quill('#description-editor', {
      theme: 'snow',
      modules: {
        toolbar: [
          ['bold', 'italic'],
          [{ list: 'bullet' }],
          ['clean'],
        ],
      },
    });

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }

    function hideError() {
      errorEl.classList.add('hidden');
    }

    dropzone.addEventListener('click', () => fileInput.click());

    dropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.classList.add('border-accent-1');
    });

    dropzone.addEventListener('dragleave', () => {
      dropzone.classList.remove('border-accent-1');
    });

    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-accent-1');
      handleFiles(e.dataTransfer.files);
    });

    fileInput.addEventListener('change', () => {
      handleFiles(fileInput.files);
    });

    async function handleFiles(files) {
      let skipped = 0;

      for (const file of files) {
        if (!['image/jpeg', 'image/png', 'image/webp', 'image/avif'].includes(file.type)) {
          skipped++;
          continue;
        }
        if (file.size > 10 * 1024 * 1024) {
          skipped++;
          continue;
        }

        const formData = new FormData();
        formData.append('image', file);

        try {
          const res = await fetch('/api/admin/upload', { method: 'POST', body: formData });
          if (res.ok) {
            const data = await res.json();
            uploadedUrls.push(data.url);
            renderPreviews();
          } else {
            skipped++;
          }
        } catch {
          skipped++;
        }
      }

      if (skipped > 0) {
        showError(`${skipped} bestand(en) overgeslagen (ongeldig type, te groot of upload mislukt).`);
      } else {
        hideError();
      }
    }

    function renderPreviews() {
      imagePreviews.innerHTML = uploadedUrls.map((url, i) => `
        <div class="relative group aspect-[4/3] rounded-lg overflow-hidden bg-gray-100 cursor-grab"
             draggable="true" data-url="${url}">
          <img src="${url}" class="w-full h-full object-cover pointer-events-none" alt="" />
          <button type="button" data-url="${url}"
            class="absolute top-2 right-2 w-7 h-7 bg-red-600 text-white rounded-full text-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:bg-red-700 z-10">&times;</button>
        </div>
      `).join('');

      imagePreviews.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', () => {
          uploadedUrls = uploadedUrls.filter(u => u !== btn.dataset.url);
          renderPreviews();
        });
      });
    }

    imagePreviews.addEventListener('dragstart', (e) => {
      const item = e.target.closest('[draggable]');
      if (!item) return;
      draggedUrl = item.dataset.url;
      e.dataTransfer.effectAllowed = 'move';
      item.classList.add('opacity-50');
    });

    imagePreviews.addEventListener('dragover', (e) => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      const item = e.target.closest('[draggable]');
      if (item && item.dataset.url !== draggedUrl) {
        item.classList.add('ring-2', 'ring-accent-1');
      }
    });

    imagePreviews.addEventListener('dragleave', (e) => {
      const item = e.target.closest('[draggable]');
      if (item) item.classList.remove('ring-2', 'ring-accent-1');
    });

    imagePreviews.addEventListener('drop', (e) => {
      e.preventDefault();
      const target = e.target.closest('[draggable]');
      if (!target || !draggedUrl || target.dataset.url === draggedUrl) return;

      const fromIndex = uploadedUrls.indexOf(draggedUrl);
      const toIndex = uploadedUrls.indexOf(target.dataset.url);
      if (fromIndex === -1 || toIndex === -1) return;

      const [moved] = uploadedUrls.splice(fromIndex, 1);
      uploadedUrls.splice(toIndex, 0, moved);
      renderPreviews();
      draggedUrl = null;
    });

    imagePreviews.addEventListener('dragend', () => {
      draggedUrl = null;
      imagePreviews.querySelectorAll('[draggable]').forEach(el => {
        el.classList.remove('opacity-50', 'ring-2', 'ring-accent-1');
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();

      const paintTypeRaw = document.getElementById('paintType').value;
      const paintType = paintTypeRaw
        ? paintTypeRaw.split(',').map(s => s.trim()).filter(Boolean)
        : [];

      const descText = descriptionEditor.getText().trim();
      if (!descText) {
        showError('Het veld "Beschrijving" is verplicht.');
        return;
      }

      const reviewDesc = document.getElementById('review-description').value.trim();
      const payload = {
        name: document.getElementById('name').value,
        paintType,
        description: descriptionEditor.root.innerHTML,
        pictures: uploadedUrls,
        review: selectedStars > 0 ? { stars: selectedStars, description: reviewDesc } : null,
      };

      try {
        const res = await fetch('/api/admin/projects', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          window.location.href = '/admin/projects';
        } else {
          const data = await res.json();
          showError(data.error || 'Opslaan mislukt');
        }
      } catch {
        showError('Er is iets misgegaan.');
      }
    });
  </script>
</AdminLayout>
