---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina niet gevonden">
  <section class="min-h-[100dvh] flex items-center justify-center">
    <div class="mx-auto max-w-[1400px] px-6 text-center reveal">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent-1 mb-6">404</p>
      <h1 class="text-6xl md:text-8xl font-bold tracking-tighter leading-[0.9] mb-6">Pagina niet gevonden</h1>
      <p class="text-neutral-500 mb-12 max-w-sm mx-auto">Deze pagina bestaat niet of is verplaatst.</p>
      <a href="/" class="inline-flex items-center justify-center px-8 py-3.5 bg-accent-1 text-white text-sm font-medium rounded-full hover:bg-accent-2 active:scale-[0.97] transition-all duration-300 ease-spring">
        Terug naar home
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</Layout>
