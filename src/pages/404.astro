---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina niet gevonden">
  <section class="py-32">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-8xl font-bold text-accent-1 mb-6">404</h1>
      <p class="text-xl text-gray-600 mb-10">Deze pagina bestaat niet.</p>
      <a href="/" class="inline-block px-8 py-4 bg-accent-1 text-white font-medium rounded-full hover:bg-accent-2 transition-colors">
        Terug naar home
      </a>
    </div>
  </section>
</Layout>
