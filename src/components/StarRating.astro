---
export interface Props {
  stars: number;
  size?: number;
}

const { stars, size = 20 } = Astro.props;
---

<div class="flex gap-1" aria-label={`${stars} van de 5 sterren`} role="img">
  {Array.from({ length: 5 }, (_, i) => {
    const pct = Math.min(1, Math.max(0, stars - i)) * 100;
    return (
      <span style={`width:${size}px;height:${size}px;position:relative;display:inline-block;flex-shrink:0`}>
        <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          class="text-gray-300" style="position:absolute;inset:0">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
        </svg>
        {pct > 0 && (
          <svg width={size} height={size} viewBox="0 0 24 24" fill="currentColor" stroke="none"
            class="text-amber-400" style={`position:absolute;inset:0;clip-path:inset(0 ${100 - pct}% 0 0)`}>
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        )}
      </span>
    );
  })}
</div>
