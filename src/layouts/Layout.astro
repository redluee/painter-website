---
import '../styles/global.css';
import { getSiteContent } from '../lib/data';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Professioneel binnen- en buitenschilderwerk in de regio Utrecht." } = Astro.props;
const { businessInfo } = getSiteContent();
---

<!doctype html>
<html lang="nl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="stylesheet" href="/api/theme.css" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap" rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Sebastiaan Peters</title>
		<meta name="description" content={description} />
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "LocalBusiness",
				"name": "Sebastiaan Peters",
				"description": "Professioneel binnen- en buitenschilderwerk",
				"url": "https://sebastiaanpeters.nl",
				"telephone": "+31612345678",
				"areaServed": "Regio Utrecht, Nederland"
			}
		</script>
	</head>
	<body class="bg-white text-gray-900 font-sans antialiased">
		<header class="border-b border-gray-100 sticky top-0 bg-navbar-bg/80 backdrop-blur-md z-50">
			<nav class="container mx-auto px-4 h-20 flex items-center justify-between">
				<a href="/" class="text-xl font-bold tracking-tight uppercase whitespace-nowrap">Sebastiaan<span class="text-accent-1 font-normal">Peters</span></a>

				<div class="hidden md:flex items-center gap-8">
					<a href="/projecten" class="text-sm font-medium hover:text-gray-500 transition-colors">Projecten</a>
					<a href="/over-mij" class="text-sm font-medium hover:text-gray-500 transition-colors">Over mij</a>
					<a href="/tarieven" class="text-sm font-medium hover:text-gray-500 transition-colors">Tarieven</a>
					<a href="/partners" class="text-sm font-medium hover:text-gray-500 transition-colors">Partners</a>
					<a href="/contact" class="px-5 py-2.5 bg-accent-1 text-white text-sm font-medium rounded-full hover:bg-accent-2 transition-colors">
						Vraag een offerte aan
					</a>
				</div>

				<button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu openen">
					<span class="block w-6 h-0.5 bg-accent-1 transition-transform duration-200"></span>
					<span class="block w-6 h-0.5 bg-accent-1 transition-opacity duration-200"></span>
					<span class="block w-6 h-0.5 bg-accent-1 transition-transform duration-200"></span>
				</button>
			</nav>

			<div id="mobile-menu" class="md:hidden hidden px-4 pb-6 border-t border-gray-100 pt-4">
				<div class="flex flex-col gap-4">
					<a href="/projecten" class="text-sm font-medium py-2 hover:text-gray-500 transition-colors">Projecten</a>
					<a href="/over-mij" class="text-sm font-medium py-2 hover:text-gray-500 transition-colors">Over mij</a>
					<a href="/tarieven" class="text-sm font-medium py-2 hover:text-gray-500 transition-colors">Tarieven</a>
					<a href="/partners" class="text-sm font-medium py-2 hover:text-gray-500 transition-colors">Partners</a>
					<a href="/contact" class="w-full py-3 bg-accent-1 text-white text-sm font-medium rounded-full text-center hover:bg-accent-2 transition-colors">
						Vraag een offerte aan
					</a>
				</div>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer class="bg-gray-50 border-t border-gray-100 py-12 mt-20">
			<div class="container mx-auto px-4 text-center">
				<div class="flex justify-center gap-4 mb-6">
					<a href="https://wa.me/{businessInfo.phone.replace(/[^\d]/g, '')}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-green-600 text-white text-sm font-medium rounded-full hover:bg-green-700 transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
						WhatsApp
					</a>
					<a href="mailto:{businessInfo.email}" class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent-1 text-white text-sm font-medium rounded-full hover:bg-accent-2 transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
						Stuur een e-mail
					</a>
				</div>
				<p class="text-sm text-gray-500 mb-4">&copy; {new Date().getFullYear()} Sebastiaan Peters. Alle rechten voorbehouden.</p>
				<p class="text-xs text-gray-400 uppercase tracking-widest">KvK: {businessInfo.kvk}</p>
			</div>
		</footer>

		<script>
			const toggle = document.getElementById('menu-toggle');
			const menu = document.getElementById('mobile-menu');
			if (toggle && menu) {
				toggle.addEventListener('click', () => {
					const isOpen = !menu.classList.contains('hidden');
					menu.classList.toggle('hidden');
					toggle.setAttribute('aria-label', isOpen ? 'Menu openen' : 'Menu sluiten');
				});
			}
		</script>
	</body>
</html>
