---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Admin | Sebastiaan Peters</title>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href="/admin/dashboard" class="text-lg font-bold text-gray-900">Admin paneel</a>
        <div class="flex items-center gap-4">
          <a href="/" class="text-sm text-gray-400 hover:text-gray-600 transition-colors" target="_blank">Bekijk site</a>
          <button id="logout-btn" class="text-sm text-gray-500 hover:text-red-600 transition-colors font-medium">Uitloggen</button>
        </div>
      </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 py-8">
      <nav class="flex gap-1 mb-8 border-b border-gray-200 pb-4 overflow-x-auto">
        <a
          href="/admin/dashboard"
          class={`px-4 py-2 text-sm font-medium rounded-lg whitespace-nowrap transition-colors ${
            currentPath === '/admin/dashboard' ? 'bg-black text-white' : 'text-gray-600 hover:bg-gray-100'
          }`}
        >
          Dashboard
        </a>
        <a
          href="/admin/content"
          class={`px-4 py-2 text-sm font-medium rounded-lg whitespace-nowrap transition-colors ${
            currentPath.startsWith('/admin/content') ? 'bg-black text-white' : 'text-gray-600 hover:bg-gray-100'
          }`}
        >
          Inhoud
        </a>
        <a
          href="/admin/projects"
          class={`px-4 py-2 text-sm font-medium rounded-lg whitespace-nowrap transition-colors ${
            currentPath.startsWith('/admin/projects') ? 'bg-black text-white' : 'text-gray-600 hover:bg-gray-100'
          }`}
        >
          Projecten
        </a>
      </nav>

      <main>
        <slot />
      </main>
    </div>

    <script>
      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        document.cookie = 'auth=; path=/; max-age=0';
        window.location.href = '/admin/login';
      });
    </script>
  </body>
</html>
