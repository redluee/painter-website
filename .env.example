# Set to 'development' to show error details; omit or set to 'production' in production
APP_ENV=production

ADMIN_EMAIL=admin@sebastiaanpeters.nl
ADMIN_PASSWORD_HASH=<bcrypt hash>
JWT_SECRET=<random secret, at least 32 chars>

# Contact form email (PHPMailer via SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@sebastiaanpeters.nl
SMTP_PASS=<smtp password>
NOTIFICATION_EMAIL=info@sebastiaanpeters.nl

# Set to empty string if using flat layout (all files in document root)
PUBLIC_DIR=public
